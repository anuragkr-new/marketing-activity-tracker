# Repo root — copy to .env (server loads this first, then server/.env if present).

DATABASE_URL=postgresql://user:pass@localhost:5432/spyne_activity
PORT=4000

# Baked into the client at build time (set in Railway for the build step).
VITE_ADMIN_PIN=1234

# Dev only: leave unset to use Vite proxy to localhost:4000 for /api.
# VITE_API_URL=http://localhost:4000
