# Repo root — copy to .env (server loads this first, then server/.env if present).

DATABASE_URL=postgresql://user:pass@localhost:5432/spyne_activity
PORT=4000

# /api/health runs SELECT 1 — returns 503 if this is missing or Postgres is unreachable.

# Baked into the client at build time (set in Railway for the build step).
VITE_ADMIN_PIN=1234

# Dev only: leave unset to use Vite proxy to localhost:4000 for /api.
# VITE_API_URL=http://localhost:4000

# If Postgres requires TLS but the URL has no sslmode=, set:
# FORCE_PG_SSL=true

# Temporary: return real error text on 500 responses (remove after fixing).
# EXPOSE_ERROR_MESSAGE=true

# On Railway, the server runs `npm run db:setup` once per boot (internal DB URL).
# Set to disable: SKIP_DB_SETUP_ON_START=true
# Non-Railway hosts: AUTO_DB_SETUP_ON_START=true to enable the same boot behavior.
