DATABASE_URL=postgresql://user:pass@localhost:5432/spyne_activity
JWT_SECRET=change_me_to_a_long_random_string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me
PORT=4000
CLIENT_ORIGIN=http://localhost:5173
# Optional: multiple origins (local + deployed client), comma-separated
# CLIENT_ORIGINS=http://localhost:5173,https://your-client.up.railway.app
#
# When true, API accepts requests without Authorization and acts as the first admin user (or first user).
# Must match client VITE_PUBLIC_MODE for the app to work without login.
# PUBLIC_API_MODE=true
